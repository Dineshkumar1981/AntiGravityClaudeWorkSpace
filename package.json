{
  "name": "antigravityclaudeworkspace",
  "version": "1.0.0",
  "description": "Blueprint App — Cloudflare Workers + D1 + Resend",
  "scripts": {
    "deploy":         "wrangler deploy",
    "dev":            "wrangler dev",
    "db:init:local":  "wrangler d1 execute blueprints-db --local  --file=schema.sql",
    "db:init:remote": "wrangler d1 execute blueprints-db --remote --file=schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
